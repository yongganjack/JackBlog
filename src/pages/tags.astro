---
import TagPill from "@/components/TagPill.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { categories, tags } from "@/data/site";
---

<BaseLayout title="分类与标签">
  <section class="container-page pb-12 pt-16">
    <div class="max-w-2xl">
      <h1 class="text-balance text-4xl font-extrabold leading-tight text-[color:var(--text)] md:text-[40px]">分类与标签</h1>
      <p class="mt-4 text-base leading-8 text-[color:var(--muted)]">按照主题浏览文章，快速找到你关心的技术和思考。</p>
    </div>

    <section class="mt-10">
      <h2 class="section-title">文章分类</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          categories.map((category) => (
            <a href={`/archive?category=${encodeURIComponent(category.name)}`} class="surface-card rounded-[20px] p-6 hover:border-[color:var(--primary)]">
              <div class="flex items-start justify-between gap-4">
                <h3 class="text-lg font-bold text-[color:var(--text)]">{category.name}</h3>
                <span class="rounded-full bg-blue-50 px-3 py-1 font-mono text-xs font-bold text-[color:var(--primary)] dark:bg-blue-400/10">{category.count}</span>
              </div>
              <p class="mt-4 text-sm leading-7 text-[color:var(--muted)]">{category.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mt-16">
      <h2 class="section-title">热门标签</h2>
      <p class="section-kicker mt-2">按使用频率和写作主题整理。</p>
      <div class="mt-6 flex flex-wrap gap-3">
        {tags.map(([tag, count]) => <TagPill label={tag} count={count} />)}
      </div>
    </section>
  </section>
</BaseLayout>
