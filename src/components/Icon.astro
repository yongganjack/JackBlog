---
type IconName =
  | "arrow-right"
  | "calendar"
  | "clock"
  | "github"
  | "mail"
  | "menu"
  | "moon"
  | "rss"
  | "search"
  | "sun"
  | "tag"
  | "x"
  | "external"
  | "home"
  | "chevron-left"
  | "chevron-right";

type Props = {
  name: IconName;
  size?: number;
  strokeWidth?: number;
  class?: string;
  decorative?: boolean;
};

const { name, size = 18, strokeWidth = 2, class: className = "", decorative = true } = Astro.props;

const paths: Record<IconName, string> = {
