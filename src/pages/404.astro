---
import Icon from "@/components/Icon.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="页面未找到">
  <section class="container-page grid min-h-[calc(100vh-9rem)] gap-10 py-16 lg:grid-cols-[0.8fr_1fr] lg:items-center">
    <div>
      <p class="font-mono text-7xl font-extrabold leading-none text-[color:var(--text)] md:text-8xl">404</p>
      <h1 class="mt-5 text-3xl font-extrabold text-[color:var(--text)]">页面走丢了</h1>
      <p class="mt-4 max-w-md text-base leading-8 text-[color:var(--muted)]">你要找的页面不存在，可能链接已经更新，或者这篇文章还在写作中。</p>
      <a href="/" class="button-primary mt-8">
        <Icon name="home" />
        返回首页
      </a>
    </div>
    <img
      src="/images/not-found.svg"
      alt="迷路的宇航员插画"
      width="760"
      height="520"
      fetchpriority="high"
      class="w-full rounded-[32px] shadow-lift"
    />
  </section>
</BaseLayout>
