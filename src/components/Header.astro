---
import { navItems, siteConfig } from "@/data/site";
import Icon from "./Icon.astro";
import ThemeToggle from "./ThemeToggle.astro";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="sticky top-0 z-50 border-b border-[color:var(--border)] bg-[color:var(--bg)]/82 backdrop-blur-xl">
  <div class="container-page flex h-16 items-center justify-between gap-6">
    <a href="/" class="flex min-w-0 items-center gap-2 rounded-full font-bold text-[color:var(--text)]" aria-label="Alex Blog 首页">
      <span class="relative grid h-9 w-9 place-items-center overflow-hidden rounded-2xl bg-gradient-to-br from-blue-500 via-sky-400 to-cyan-300 text-white shadow-soft ring-1 ring-blue-500/20 dark:from-blue-400 dark:via-cyan-300 dark:to-teal-200 dark:text-slate-950">
        <span class="absolute -right-1 -top-1 h-4 w-4 rounded-full bg-white/35 blur-[1px]"></span>
        <span class="relative font-mono text-lg font-extrabold leading-none" translate="no">J</span>
      </span>
      <span translate="no">{siteConfig.name}</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="主导航">
      {
        navItems.map((item) => {
          const isActive = item.href === currentPath;
          return (
            <a
              href={item.href}
              aria-current={isActive ? "page" : undefined}
              class:list={[
                "rounded-full px-3 py-2 text-sm font-semibold transition-colors hover:bg-slate-100 hover:text-[color:var(--text)] dark:hover:bg-white/10",
                isActive ? "text-[color:var(--primary)]" : "text-[color:var(--muted)]"
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-1">
      <a
        href="/search"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full text-[color:var(--body)] transition-colors hover:bg-slate-100 hover:text-[color:var(--text)] dark:hover:bg-white/10"
        aria-label="搜索文章"
      >
        <Icon name="search" />
      </a>
      <ThemeToggle />
      <a
        href={siteConfig.socials.github}
        class="hidden h-10 w-10 items-center justify-center rounded-full text-[color:var(--body)] transition-colors hover:bg-slate-100 hover:text-[color:var(--text)] dark:hover:bg-white/10 sm:inline-flex"
        aria-label="打开 GitHub"
      >
        <Icon name="github" />
      </a>
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full text-[color:var(--body)] transition-colors hover:bg-slate-100 hover:text-[color:var(--text)] dark:hover:bg-white/10 md:hidden"
        aria-label="打开导航菜单"
        aria-controls="mobile-menu"
        aria-expanded="false"
        data-menu-toggle
      >
        <Icon name="menu" />
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="container-page hidden border-t border-[color:var(--border)] py-3 md:hidden" aria-label="移动端导航" data-mobile-menu>
    <div class="grid gap-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="rounded-2xl px-3 py-3 text-sm font-semibold text-[color:var(--body)] transition-colors hover:bg-slate-100 hover:text-[color:var(--text)] dark:hover:bg-white/10"
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script is:inline>
  (() => {
    const button = document.querySelector("[data-menu-toggle]");
    const menu = document.querySelector("[data-mobile-menu]");
    if (!button || !menu) return;
    button.addEventListener("click", () => {
      const expanded = button.getAttribute("aria-expanded") === "true";
      button.setAttribute("aria-expanded", String(!expanded));
      menu.classList.toggle("hidden", expanded);
    });
  })();
</script>
