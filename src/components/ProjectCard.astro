---
import type { Project } from "@/data/site";
import Icon from "./Icon.astro";

type Props = {
  project: Project;
};

const { project } = Astro.props;
---

<article class="surface-card group grid h-full overflow-hidden rounded-[20px] p-4 transition-transform hover:-translate-y-1">
  <img
    src={project.image}
    alt=""
    width="640"
    height="400"
    loading="lazy"
    class="aspect-[16/10] w-full rounded-2xl object-cover"
  />
  <div class="mt-5">
    <h3 class="text-lg font-bold text-[color:var(--text)]">{project.name}</h3>
    <p class="mt-2 min-h-14 text-sm leading-7 text-[color:var(--muted)]">{project.description}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {project.stack.map((item) => <span class="rounded-full bg-[color:var(--surface-soft)] px-3 py-1 text-xs font-semibold text-[color:var(--body)]">{item}</span>)}
    </div>
    <div class="mt-5 flex gap-2">
      <a href={project.github} class="button-secondary min-h-10 px-3 py-2 text-xs" aria-label={`打开 ${project.name} GitHub`}>
        <Icon name="github" size={15} />
        GitHub
      </a>
      <a href={project.demo} class="button-secondary min-h-10 px-3 py-2 text-xs" aria-label={`打开 ${project.name} Demo`}>
        <Icon name="external" size={15} />
        Demo
      </a>
    </div>
  </div>
</article>
