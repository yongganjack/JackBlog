---
import Icon from "@/components/Icon.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig, timeline } from "@/data/site";

const researchExperiences = [
  {
    time: "2025.11",
    type: "竞赛",
    title: "高教社杯全国大学生数学建模竞赛-全国一等奖",
    description: "负责数学模型建立与算法实现，完成模型求解、程序开发及结果分析，参与论文撰写。"
  },
  {
    time: "2024.10",
    type: "竞赛",
    title: "高教社杯全国大学生数学建模竞赛-湖南赛区一等奖",
    description: "负责数学模型建立与算法实现，完成模型求解、程序开发及结果分析，参与论文撰写。"
  },
  {
    time: "2024.04",
    type: "竞赛",
    title: "蓝桥杯全国软件和信息技术专业人才大赛-湖南赛区二等奖（B组）",
    description: "完成算法设计、程序开发及调试优化等任务。"
  }
] as const;
---

<BaseLayout title="关于">
  <section class="container-page grid gap-10 pb-12 pt-16 lg:grid-cols-[360px_1fr]">
    <aside class="surface-card h-max rounded-[28px] p-6">
      <img
        src="/images/avatar.svg"
        alt="Alex 的头像插画"
        width="420"
        height="420"
        fetchpriority="high"
        class="mx-auto aspect-square w-44 rounded-full"
      />
      <h1 class="mt-6 text-center text-3xl font-extrabold text-[color:var(--text)]">Jack</h1>
      <p class="mt-2 text-center text-sm leading-7 text-[color:var(--muted)]">{siteConfig.role}</p>
      <div class="mt-6 flex justify-center gap-2">
        <a class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[color:var(--border)] text-[color:var(--body)] hover:text-[color:var(--primary)]" href={siteConfig.socials.github} aria-label="GitHub">
          <Icon name="github" />
        </a>
        <a class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[color:var(--border)] text-[color:var(--body)] hover:text-[color:var(--primary)]" href={siteConfig.socials.email} aria-label="发送邮件">
          <Icon name="mail" />
        </a>
        <a class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[color:var(--border)] text-[color:var(--body)] hover:text-[color:var(--primary)]" href={siteConfig.socials.x} aria-label="X 主页">
          <Icon name="x" />
        </a>
      </div>
    </aside>

    <div class="min-w-0">
      <div class="surface-card rounded-[28px] p-6 md:p-8">
        <h2 class="section-title">关于我</h2>
        <p class="mt-5 text-base leading-8 text-[color:var(--body)]">
          我是重邮26级计算机研究生，最近正在完成师兄安排的暑期基础任务，主要与大模型应用相关。 目前的学习任务包括搭建一个可以简单使用的 Agent，后续会在不定期更新学习记录和项目代码。 欢迎大家给仓库点个 Star ⭐，感谢支持！🙏
        </p>
      </div>

      <section class="mt-8">
        <h2 class="section-title">科研/竞赛经历</h2>
        <div class="surface-card mt-5 rounded-[20px] p-5 md:p-6">
          <div class="divide-y divide-[color:var(--border)]">
            {
              researchExperiences.map((item) => (
                <article class="py-5 first:pt-0 last:pb-0 md:grid md:grid-cols-[7rem_1fr] md:gap-6">
                  <div class="flex items-center gap-3 md:block">
                    <div class="font-mono text-sm font-bold tabular-nums text-[color:var(--primary)]">{item.time}</div>
                    <span class="inline-flex rounded-full border border-[color:var(--border)] px-3 py-1 text-xs font-bold text-[color:var(--primary)] md:mt-3">
                      {item.type}
                    </span>
                  </div>
                  <div class="mt-3 min-w-0 md:mt-0">
                    <h3 class="font-bold text-[color:var(--text)]">{item.title}</h3>
                    <p class="mt-2 text-sm leading-7 text-[color:var(--muted)]">{item.description}</p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section class="mt-10">
        <h2 class="section-title">教育经历</h2>
        <div class="timeline-list mt-6">
          {
            timeline.map((item, index) => (
              <article class={`timeline-item ${index % 2 === 0 ? "timeline-item-left" : "timeline-item-right"}`}>
                <div class="timeline-node" aria-hidden="true"></div>
                <div class="surface-card timeline-card rounded-[20px] p-5">
                  <div class="font-mono text-sm font-bold tabular-nums text-[color:var(--primary)]">{item.year}</div>
                  <div class="mt-3">
                    <h3 class="font-bold text-[color:var(--text)]">{item.title}</h3>
                    <p class="mt-2 text-sm leading-7 text-[color:var(--muted)]">{item.body}</p>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </section>
    </div>
  </section>
</BaseLayout>

<style>
  .timeline-list {
    position: relative;
    display: grid;
    gap: 1.5rem;
    padding-left: 2rem;
  }

  .timeline-list::before {
    position: absolute;
    left: 0.5rem;
    top: 0.75rem;
    bottom: 0.75rem;
    width: 2px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--primary) 38%, var(--border));
    content: "";
  }

  .timeline-item {
    position: relative;
  }

  .timeline-node {
    position: absolute;
    left: -1.875rem;
    top: 1.35rem;
    z-index: 1;
    width: 0.75rem;
    height: 0.75rem;
    border: 2px solid var(--surface);
    border-radius: 999px;
    background: var(--primary);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--primary) 16%, transparent);
  }

  .timeline-card {
    position: relative;
  }

  @media (min-width: 640px) {
    .timeline-list {
      gap: 0;
      padding-left: 0;
    }

    .timeline-list::before {
      left: 50%;
      transform: translateX(-50%);
    }

    .timeline-item {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      min-height: 8.5rem;
    }

    .timeline-item + .timeline-item {
      margin-top: -0.5rem;
    }

    .timeline-node {
      left: 50%;
      top: 1.65rem;
      transform: translateX(-50%);
    }

    .timeline-card {
      width: calc(100% - 2.5rem);
    }

    .timeline-item-left .timeline-card {
      grid-column: 1;
      justify-self: start;
      text-align: right;
    }

    .timeline-item-right .timeline-card {
      grid-column: 2;
      justify-self: end;
    }
  }
</style>
